{
  "name": "@app/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "dev": "pnpm run copy-tinybird-tracker && dotenvx run -f ../../.env.local -- next dev",
    "copy-tinybird-tracker": "cp ../../packages/tinybird/dist/tracker.js  public/assets",
    "build:frontend": "next build --webpack",
    "start:frontend": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "cloudflare:build": "prisma generate --schema ../../packages/prisma/prisma/schema.prisma && node ./replace-wasm.js && npx opennextjs-cloudflare build && node ./dedupe-handler.js",
    "cloudflare:preview": "pnpm run cloudflare:build && npx wrangler dev",
    "cloudflare:deploy": "pnpm run cloudflare:build && npx wrangler deploy --minify"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.1.5",
    "@number-flow/react": "^0.4.2",
    "@prisma/adapter-d1": "^7.8.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-google-maps/api": "^2.20.3",
    "@reactour/tour": "^3.7.0",
    "@app/blocks": "workspace:*",
    "@app/common": "workspace:*",
    "@app/prisma": "workspace:*",
    "@app/tinybird": "workspace:*",
    "@app/ui": "workspace:*",
    "better-auth": "^1.4.3",
    "date-fns": "^4.1.0",
    "formik": "^2.4.6",
    "formik-validator-zod": "^2.0.1",
    "framer-motion": "^12.0.0-alpha.1",
    "lucide-react": "^0.454.0",
    "mapbox-gl": "^3.10.0",
    "next": "16.2.6",
    "posthog-js": "^1.187.1",
    "react": "^19.0.0",
    "react-color": "^2.19.3",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^1.5.0",
    "react-qr-code": "^2.0.15",
    "recharts": "^2.13.0",
    "safe-await": "^2.0.0",
    "sass": "^1.85.0",
    "server-only": "^0.0.1",
    "stripe": "^17.3.1",
    "swr": "^2.2.5",
    "uuid": "^11.0.2",
    "yup": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.4",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "22.8.7",
    "@types/react": "^19.0.10",
    "@types/react-color": "^3.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/react-grid-layout": "^1.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "autoprefixer": "^10.4.20",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "8.4.47",
    "prisma": "^7.0.0",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "typescript": "5.6.3",
    "wrangler": "^4.95.0"
  }
}